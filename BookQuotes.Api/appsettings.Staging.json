{
  "AllowedHosts": "staging-api.bookquotes.example",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "Postgres"
  },
  "Jwt": {
    "Issuer": "BookQuotesApi",
    "Audience": "BookQuotesClient",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": "https://staging.bookquotes.example",
    "AllowedMethods": "GET,POST,PUT,DELETE,OPTIONS",
    "AllowedHeaders": "Authorization,Content-Type",
    "AllowCredentials": true
  },
  "DataProtection": {
    "KeyPath": "/keys"
  }
}
